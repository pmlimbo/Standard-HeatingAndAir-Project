digraph model_graph {
  // Dotfile by Django-Extensions graph_models
  // Created: 2026-03-31 16:26
  // Cli Options: core --dot -o erd.dot

  fontname = "Roboto"
  fontsize = 8
  splines  = true
  rankdir = "TB"
  

  node [
    fontname = "Roboto"
    fontsize = 8
    shape = "plaintext"
  ]

  edge [
    fontname = "Roboto"
    fontsize = 8
  ]

  // Labels


  core_models_Customer [label=<
